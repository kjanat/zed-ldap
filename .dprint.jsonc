{
	"extends": "https://raw.githubusercontent.com/kjanat/kjanat/refs/heads/master/configs/dprint.remote.json",
	"excludes": ["tree-sitter.json", "src/*.json"],
	"exec": {
		"cwd": "${configDir}",
		"cacheKey": "1",
		"timeout": 30,
		"commands": [{ "command": "rustfmt --edition 2024", "exts": ["rs"] }]
	},
	"plugins": [
		"https://plugins.dprint.dev/exec-0.7.2.json@6c30bd00dfb176774ece412d0fbf149478269ecc92c55ab2d6f4116938ed993e",
	],
}
